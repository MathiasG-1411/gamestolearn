# Supabase — copier ce fichier en .env.local et remplir les valeurs
# Récupérer ces clés dans : Supabase Dashboard > Settings > API

# URL de votre projet Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Clé publique (anon) — exposée côté client, sécurisée par RLS
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Clé service role — NE JAMAIS exposer côté client
# Utilisée uniquement dans les Server Actions / API routes
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# Secret de signature de la session élève (HMAC) — NE JAMAIS exposer côté client
# Signe le cookie student_id pour empêcher l'usurpation d'un autre élève.
# Générer une valeur aléatoire (≥ 16 caractères), ex : openssl rand -base64 32
STUDENT_SESSION_SECRET=change-me-with-a-long-random-secret
